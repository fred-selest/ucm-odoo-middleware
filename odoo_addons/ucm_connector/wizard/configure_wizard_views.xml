<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire wizard -->
    <record id="ucm_configure_wizard_view_form" model="ir.ui.view">
        <field name="name">ucm.configure.wizard.view.form</field>
        <field name="model">ucm.configure.wizard</field>
        <field name="arch" type="xml">
            <form string="Configuration UCM">
                <group>
                    <group string="Middleware">
                        <field name="middleware_url"/>
                        <field name="api_key" password="True"/>
                        <field name="is_connected" readonly="1"/>
                    </group>
                    <group string="UCM6300">
                        <field name="ucm_host"/>
                        <field name="ucm_port"/>
                        <field name="ucm_username"/>
                        <field name="ucm_password" password="True"/>
                    </group>
                </group>
                <group string="Odoo">
                    <field name="odoo_url"/>
                    <field name="odoo_db"/>
                </group>
                <footer>
                    <button name="action_test_connection" type="object" string="Tester connexion" 
                            class="btn-secondary"/>
                    <button name="action_save_config" type="object" string="Enregistrer" 
                            class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Action -->
    <record id="ucm_configure_wizard_action" model="ir.actions.act_window">
        <field name="name">Configuration UCM</field>
        <field name="res_model">ucm.configure.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
