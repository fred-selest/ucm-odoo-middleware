<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajouter bouton appels dans fiche contact -->
    <record id="res_partner_view_inherit_ucm" model="ir.ui.view">
        <field name="name">res.partner.view.inherit.ucm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_ucm_calls" type="object" class="oe_stat_button" icon="fa-phone">
                    <field name="ucm_call_count" widget="statinfo" string="Appels"/>
                </button>
            </div>
            
            <!-- Ajouter bouton click-to-call près du téléphone -->
            <field name="phone" position="after">
                <button name="action_ucm_click_to_call" type="object" 
                        class="btn-link" icon="fa-phone"
                        attrs="{'invisible': [('phone', '=', False)]}"
                        context="{'phone': phone}"
                        title="Cliquer pour appeler"/>
            </field>
            <field name="mobile" position="after">
                <button name="action_ucm_click_to_call" type="object" 
                        class="btn-link" icon="fa-mobile"
                        attrs="{'invisible': [('mobile', '=', False)]}"
                        context="{'phone': mobile}"
                        title="Cliquer pour appeler"/>
            </field>
        </field>
    </record>
</odoo>
