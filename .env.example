# ── UCM Mode Selection ─────────────────────────────────────────────────────
# Mode: 'websocket' ou 'webhook' (recommandé - sans VPN)
UCM_MODE=webhook

# ── UCM Host Configuration ─────────────────────────────────────────────────
UCM_HOST=192.168.1.100

# ── UCM WebSocket Configuration ───────────────────────────────────────────
UCM_WEB_PORT=8089
UCM_WEB_USER=admin
UCM_WEB_PASSWORD=your_web_password

# Délai de reconnexion (ms)
UCM_RECONNECT_DELAY=3000
UCM_RECONNECT_MAX_DELAY=60000

# Extensions à surveiller (séparées par virgule, vide = toutes)
UCM_WATCH_EXTENSIONS=

# ── Odoo ──────────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=api_user@example.com
ODOO_API_KEY=your_odoo_api_key

# Timeout requêtes Odoo (ms)
ODOO_TIMEOUT=8000

# TTL du cache contacts (secondes)
CACHE_CONTACT_TTL=300

# ── Base de données (SQLite) ──────────────────────────────────────────────
DB_PATH=/app/data/middleware.db

# Retention des données (jours) - 0 pour illimité
DATA_RETENTION_DAYS=365

# ── Serveur HTTP / WebSocket ───────────────────────────────────────────────
SERVER_PORT=3000
WS_PATH=/ws

# Clé secrète pour l'API REST (header X-API-Key)
API_SECRET_KEY=change_me_in_production

# ── SIRENE INSEE (enrichissement fiches clients) ────────────────────────
# Clé API obtenue sur https://portail-api.insee.fr
INSEE_SIRENE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_OUTPUT=both
LOG_DIR=./logs

# ── Application ───────────────────────────────────────────────────────────
NODE_ENV=production
