# ── UCM Mode Selection ─────────────────────────────────────────────────────
# Mode: 'websocket' ou 'webhook' (recommandé - sans VPN)
UCM_MODE=webhook

# ── UCM Host Configuration ─────────────────────────────────────────────────
UCM_HOST=192.168.1.100

# ── UCM WebSocket Configuration ───────────────────────────────────────────
UCM_WEB_PORT=8089
UCM_WEB_USER=admin
UCM_WEB_PASSWORD=your_web_password

# Délai de reconnexion (ms)
UCM_RECONNECT_DELAY=3000
UCM_RECONNECT_MAX_DELAY=60000

# Extensions à surveiller (séparées par virgule, vide = toutes)
UCM_WATCH_EXTENSIONS=

# ── Odoo ──────────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=api_user@example.com
ODOO_API_KEY=your_odoo_api_key

# Timeout requêtes Odoo (ms)
ODOO_TIMEOUT=8000

# TTL du cache contacts (secondes)
CACHE_CONTACT_TTL=300

# ── Base de données (SQLite) ──────────────────────────────────────────────
DB_PATH=/app/data/middleware.db

# Retention des données (jours) - 0 pour illimité
DATA_RETENTION_DAYS=365

# ── Serveur HTTP / WebSocket ───────────────────────────────────────────────
SERVER_PORT=3000
WS_PATH=/ws

# Clé secrète pour l'API REST (header X-API-Key)
API_SECRET_KEY=change_me_in_production

# ── SIRENE INSEE (enrichissement fiches clients) ────────────────────────
# Clé API obtenue sur https://portail-api.insee.fr
INSEE_SIRENE_API_KEY=

# ── Google Places (téléphone + site web entreprises) ─────────────────────
# Clé API obtenue sur https://console.cloud.google.com (activer Places API)
GOOGLE_PLACES_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_OUTPUT=both
LOG_DIR=./logs

# ── Notifications (Telegram, Email, Web Push) ────────────────────────────
# Token du bot Telegram (créer via @BotFather)
TELEGRAM_TOKEN=
# Chat IDs (JSON array) : IDs des canaux/groupes/utilisateurs
TELEGRAM_CHAT_IDS=[]

# SMTP Configuration pour les emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@entreprise.com
SMTP_DEFAULT_RECIPIENTS=

# Seuil d'alerte appels manqués
NOTIFICATION_MISSED_CALL_COUNT=3
NOTIFICATION_MISSED_CALL_MINUTES=15

# Résumé quotidien
NOTIFICATION_DAILY_SUMMARY_ENABLED=false
NOTIFICATION_DAILY_SUMMARY_TIME=18:00

# ── CDR Auto-Sync ──────────────────────────────────────────────────────
# Synchronisation automatique des CDR depuis le UCM
CDR_SYNC_ENABLED=true
CDR_SYNC_INTERVAL_MS=300000

# ── Whisper Transcription (optionnel) ─────────────────────────────────
# Transcription automatique des enregistrements
WHISPER_ENABLED=false
# Mode : 'local' (openai-whisper CLI installé sur le serveur) ou 'api' (OpenAI / Groq)
WHISPER_MODE=local
# Modèle local : tiny (rapide, léger) | base | small | medium | large
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=fr
WHISPER_COMMAND=
WHISPER_MAX_DURATION=600
# Mode API uniquement (laisser vide en mode local)
WHISPER_API_KEY=
# OpenAI (défaut) :
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
# Groq (plus rapide, moins cher, modèle whisper-large-v3) :
# WHISPER_API_URL=https://api.groq.com/openai/v1/audio/transcriptions

# ── Application ───────────────────────────────────────────────────────────
NODE_ENV=production
